# =============================================================================
# SANTTORINI ERP — .env.example
# Bloco 4: Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha com seus valores reais.
# NUNCA comite .env.local no git.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — Variáveis PÚBLICAS (prefixo NEXT_PUBLIC_)
# Expostas no browser. Não armazenar segredos aqui.
# -----------------------------------------------------------------------------

# URL pública da API do Supabase (Kong gateway ou domínio customizado)
# Dev local:  http://localhost:8000
# Produção:   https://santtorini.qarvon.com/api  (via reverse proxy EasyPanel)
#             OU https://<project-ref>.supabase.co (Supabase hosted)
SYSTEM_USER_ID=your-system-user-uuid-here

NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000

# Chave anônima — acesso público, respeitará RLS policies
# Obtenha em: Supabase Dashboard > Project Settings > API > anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# SUPABASE — Variáveis PRIVADAS (servidor apenas, sem prefixo NEXT_PUBLIC_)
# Nunca importar em componentes client. Usar apenas em API Routes e Server Actions.
# -----------------------------------------------------------------------------

# Service Role Key — bypassa RLS, acesso total. Usar APENAS no servidor.
# Obtenha em: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret — para validação de tokens no middleware (se necessário)
# Deve coincidir com JWT_SECRET do Supabase stack
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------

# URL canônica do app (usada em redirects OAuth e emails)
# Dev: http://localhost:3000
# Produção: https://santtorini.qarvon.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret para proteger endpoints de cron jobs (/api/jobs/*)
# Gere com: openssl rand -hex 32
CRON_SECRET=replace-with-a-random-secret-32chars

# -----------------------------------------------------------------------------
# NOTAS DE CONFIGURAÇÃO PARA PRODUÇÃO
# -----------------------------------------------------------------------------
# 1. NEXT_PUBLIC_SUPABASE_URL em produção:
#    - Se Supabase self-hosted com subdomínio próprio:
#      NEXT_PUBLIC_SUPABASE_URL=https://supabase.santtorini.qarvon.com
#    - Se usando Supabase Cloud:
#      NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
#
# 2. No EasyPanel, configure as env vars acima no painel de variáveis do serviço.
#    Nunca crie .env.local no container de produção.
#
# 3. SUPABASE_SERVICE_ROLE_KEY nunca aparece no bundle do client.
#    O Next.js garante isso — variáveis sem NEXT_PUBLIC_ só existem no servidor.
#
# 4. Para o stack Supabase self-hosted, API_EXTERNAL_URL deve apontar para
#    o mesmo valor de NEXT_PUBLIC_SUPABASE_URL configurado aqui.
